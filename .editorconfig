# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across editors and contributors.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false  # Trailing spaces = intentional line breaks in Markdown

[*.toml]
indent_size = 2

[*.yml]
indent_size = 2
