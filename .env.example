# .env.example — copy to .env and fill in your values
# All keys can also be configured from within the app (Settings → API Groq).

# ── Required ──────────────────────────────────────────────────────────────────
# Groq API key — free tier available at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Models (optional — defaults shown) ────────────────────────────────────────
WHISPER_MODEL=whisper-large-v3-turbo
LLM_MODEL=llama-3.3-70b-versatile

# ── Audio ─────────────────────────────────────────────────────────────────────
# Display name of the microphone to use. Leave empty to use the system default.
MICROPHONE=

# ── Hotkeys ───────────────────────────────────────────────────────────────────
HOTKEY_DICTATE=right ctrl+right shift
HOTKEY_CONTEXT=right alt+right shift
HOTKEY_DICTATE_MODE=hold
HOTKEY_CONTEXT_MODE=hold

# ── Behaviour ─────────────────────────────────────────────────────────────────
CONFIRMATION_SOUND=true
SHOW_OVERLAY=true

# ── Language ──────────────────────────────────────────────────────────────────
# UI language: "en" (English, default) or "fr" (Français)
UI_LANGUAGE=en

# Dictation/transcription language (ISO 639-1 code, passed to Whisper)
# Supported: en, fr, es, de, it  (default: en)
DICTATION_LANGUAGE=en
